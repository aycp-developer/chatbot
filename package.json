{
	"name": "chatbot-server",
	"type": "module",
	"version": "1.0.0",
	"description": "ChatBot API REST with Gemini integration",
	"main": "dist/index.js",
	"scripts": {
		"dev": "tsx watch src/index.ts",
		"build": "tsc",
		"start": "node dist/index.js",
		"lint:check": "eslint src --ext .ts",
		"lint:fix": "eslint src --ext .ts --fix",
