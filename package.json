	},
	"devDependencies": {
		"@eslint/js": "^10.0.1",
		"@types/cors": "^2.8.17",
		"@types/express": "^4.17.21",
		"@types/node": "^22.5.4",
		"@types/supertest": "^7.2.0",
		"@typescript-eslint/eslint-plugin": "^8.57.1",
		"@typescript-eslint/parser": "^8.57.1",
		"globals": "^17.4.0",
		"supertest": "^7.2.2",
		"tsx": "^4.19.1",
		"typescript": "^5.6.2",
		"vitest": "^4.1.0"
